generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id                    String                @id @default(cuid())
  slug                  String                @unique
  sku                   String?               @unique
  oemReference          String?
  alternativeReferences String[]              @default([])
  category              String
  name                  String
  brand                 String
  price                 Int
  previousPrice         Int
  stock                 Int                   @default(12)
  minimumStock          Int                   @default(3)
  image                 String
  galleryImages         String[]              @default([])
  availability          String
  description           String
  application           String?
  compatibility         String[]              @default([])
  warranty              String?
  technicalSpecs        Json?
  featured              Boolean               @default(false)
  active                Boolean               @default(true)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  colorVariants         Json?                 @default("[]")
  videoUrl              String?
  campaigns             Campaign[]
  inventoryMovements    InventoryMovement[]
  priceHistory          PriceHistory[]
  saleCalculatorItems   SaleCalculatorItem[]
  quotationItems        QuotationItem[]
  productionRuns        ProductionRun[]
  productionOrderItems  ProductionOrderItem[]
  comboItems            ComboItem[]
  warehouseStocks       ProductWarehouseStock[]
  warehouseMovements    WarehouseMovement[]
}

model User {
  id                       String             @id @default(cuid())
  fullName                 String
  company                  String?
  email                    String             @unique
  phone                    String?
  department               String?
  city                     String?
  addressLine1             String?
  addressLine2             String?
  passwordHash             String
  role                     UserRole           @default(CUSTOMER)
  status                   UserStatus         @default(ACTIVE)
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  level                    CustomerLevel      @default(AQUA)
  points                   Int                @default(0)
  bonusBalance             Int                @default(0)
  bonusExpiry              DateTime?
  kTier                    String             @default("NONE")
  monthlyPeriod            String             @default("")
  whatsappPhone            String?
  campaigns                Campaign[]         @relation("CampaignSeller")
  cartItems                CartItem[]
  assignedOrders           Order[]            @relation("AssignedOrders")
  orders                   Order[]
  pointTransactions        PointTransaction[]
  priceChanges             PriceHistory[]     @relation("PriceChangedBy")
  rewardRedemptions        RewardRedemption[]
  costConfig               SellerCostConfig?
  saleCalculators          SaleCalculator[]
  quotationsAsSeller       Quotation[]        @relation("QuotationSeller")
  permissions              UserPermission[]
  quotationsAsClient       Quotation[]        @relation("QuotationClient")
  productionRuns           ProductionRun[]    @relation("ProductionOperator")
  productionOrdersCreated  ProductionOrder[]  @relation("ProductionOrderCreatedBy")
  productionOrdersApproved ProductionOrder[]  @relation("ProductionOrderApprovedBy")
  employee                 Employee?
}

model CartItem {
  id            String   @id @default(cuid())
  userId        String
  productId     String?
  comboId       String?
  name          String
  price         String
  image         String
  quantity      Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  originalPrice String?
  sku           String?
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  combo         Combo?   @relation(fields: [comboId], references: [id])

  @@unique([userId, productId])
  @@unique([userId, comboId])
}

model Order {
  id                 String         @id @default(cuid())
  userId             String
  status             OrderStatus    @default(PENDING)
  paymentStatus      PaymentStatus  @default(PENDING)
  shippingStatus     ShippingStatus @default(PENDING)
  channel            OrderChannel   @default(ONLINE)
  customerName       String
  customerEmail      String
  customerPhone      String
  company            String?
  department         String
  city               String
  addressLine1       String
  addressLine2       String?
  notes              String?
  carrier            String?
  trackingNumber     String?
  adminNotes         String?
  shippedAt          DateTime?
  deliveredAt        DateTime?
  subtotal           Int
  totalItems         Int
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  assignedSellerId   String?
  odooOrderId        Int?
  odooOrderName      String?
  odooSyncStatus     OdooSyncStatus @default(NOT_SYNCED)
  odooSyncError      String?
  odooSyncedAt       DateTime?
  wompiReference     String?        @unique
  wompiTransactionId String?
  assignedSeller     User?          @relation("AssignedOrders", fields: [assignedSellerId], references: [id])
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items              OrderItem[]
  quotation          Quotation?
}

enum OdooSyncStatus {
  NOT_SYNCED
  SYNCED
  FAILED
}

enum OrderChannel {
  ONLINE
  WHATSAPP
  MARKETPLACE
  OTHER
}

model OrderItem {
  id            String   @id @default(cuid())
  orderId       String
  productId     String?
  comboId       String?
  comboSnapshot Json?
  name          String
  image         String
  unitPrice     Int
  quantity      Int
  lineTotal     Int
  sku           String?
  createdAt     DateTime @default(now())
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model InventoryMovement {
  id         String                @id @default(cuid())
  productId  String
  type       InventoryMovementType
  quantity   Int
  stockAfter Int
  note       String?
  createdAt  DateTime              @default(now())
  product    Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model PointTransaction {
  id          String               @id @default(cuid())
  userId      String
  type        PointTransactionType
  points      Int
  balance     Int
  description String
  orderId     String?
  createdAt   DateTime             @default(now())
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Reward {
  id          String             @id @default(cuid())
  name        String
  description String
  pointsCost  Int
  image       String?
  active      Boolean            @default(true)
  stock       Int?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  redemptions RewardRedemption[]
}

model RewardRedemption {
  id        String   @id @default(cuid())
  userId    String
  rewardId  String
  points    Int
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  reward    Reward   @relation(fields: [rewardId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PriceHistory {
  id        String   @id @default(cuid())
  productId String
  oldPrice  Int
  newPrice  Int
  changedBy String
  note      String?
  createdAt DateTime @default(now())
  user      User     @relation("PriceChangedBy", fields: [changedBy], references: [id])
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Campaign {
  id             String          @id @default(cuid())
  name           String
  sellerId       String
  productId      String?
  investment     Float           @default(0)
  sales          Float           @default(0)
  targetMultiple Float           @default(10)
  status         String          @default("ACTIVE")
  platform       String          @default("Meta Ads")
  startDate      DateTime        @default(now())
  endDate        DateTime?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  leads          Int             @default(0)
  product        Product?        @relation(fields: [productId], references: [id])
  seller         User            @relation("CampaignSeller", fields: [sellerId], references: [id])
  dailyEntries   CampaignDaily[]
}

model CampaignDaily {
  id                    String   @id @default(cuid())
  campaignId            String
  fecha                 DateTime
  mensajes              Int      @default(0)
  transacciones         Int      @default(0)
  presupuestoPublicidad Float    @default(0)
  ventaDelDia           Float    @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  campaign              Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, fecha])
  @@index([campaignId])
}

model SellerCostConfig {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  costoProd       Float    @default(0)
  publicidad      Float    @default(0)
  transporte      Float    @default(0)
  packing         Float    @default(0)
  recaudo         Float    @default(0)
  imprevistos     Float    @default(5)
  gastosFijos     Float    @default(0)
  devolucionesPct Float    @default(0)
  updatedAt       DateTime @updatedAt
}

model SaleCalculator {
  id          String               @id @default(cuid())
  userId      String
  name        String               @default("Nuevo combo")
  envio       Float                @default(0)
  picking     Float                @default(0)
  comisionPct Float                @default(2.5)
  margenPct   Float                @default(25)
  campanaPct  Float                @default(10)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  user        User                 @relation(fields: [userId], references: [id])
  items       SaleCalculatorItem[]

  @@index([userId])
}

model SaleCalculatorItem {
  id             String         @id @default(cuid())
  calculatorId   String
  productId      String?
  nombreProducto String
  cantidad       Int            @default(1)
  costoUnitario  Float          @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  calculator     SaleCalculator @relation(fields: [calculatorId], references: [id], onDelete: Cascade)
  product        Product?       @relation(fields: [productId], references: [id])

  @@index([calculatorId])
}

model Machine {
  id        String          @id @default(cuid())
  code      Int             @unique
  name      String
  brand     String
  model     String?
  location  String?
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  runs      ProductionRun[]

  @@index([isActive])
}

model ProductionRun {
  id             String   @id @default(cuid())
  machineId      String
  machine        Machine  @relation(fields: [machineId], references: [id])
  operatorId     String
  operator       User     @relation("ProductionOperator", fields: [operatorId], references: [id])
  productId      String?
  product        Product? @relation(fields: [productId], references: [id])
  orderNumber    String
  productionDate DateTime
  startTime      DateTime
  endTime        DateTime

  productionOrderId String?
  productionOrder   ProductionOrder? @relation(fields: [productionOrderId], references: [id])

  material        String
  pigment         String?
  injectionWeight Float
  pieceWeight     Float
  cycle           Float
  temperature     Float

  produced      Int
  damaged       Int @default(0)
  nonConforming Int @default(0)

  couplingTest String?
  observations String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([machineId])
  @@index([operatorId])
  @@index([productionDate])
  @@index([productionOrderId])
}

enum UserRole {
  CUSTOMER
  ADMIN
  SELLER
  PACKING
  SUPERADMIN
  RRHH
  EMPLOYEE
  BODEGA
  DISENO
  MARKETING
  JEFE_VENTAS
  TESORERIA
  INGENIERIA
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum PanelModule {
  MODULE_DASHBOARD
  MODULE_PEDIDOS
  MODULE_PRODUCTOS
  MODULE_METRICAS
  MODULE_CAMPANAS
  MODULE_COSTOS
  MODULE_CALCULADORA_PRECIO
  MODULE_COTIZACIONES
  MODULE_PRODUCCION
  MODULE_ODOO
  MODULE_USUARIOS
  MODULE_BANNERS
  MODULE_COMBOS
  MODULE_RRHH
  MODULE_OUTLET
  MODULE_BODEGAS
}

enum BannerType {
  CATEGORY
  SITE
}

model Banner {
  id           String     @id @default(cuid())
  key          String     @unique
  type         BannerType
  title1       String?
  title2       String?
  desktopImage String?
  mobileImage  String?
  link         String?
  metadata     Json?
  active       Boolean    @default(true)
  order        Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Combo {
  id          String      @id @default(cuid())
  slug        String      @unique
  sku         String      @unique
  name        String
  description String?
  image       String?
  price       Int
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  items       ComboItem[]
  cartItems   CartItem[]
}

model ComboItem {
  id        String  @id @default(cuid())
  comboId   String
  combo     Combo   @relation(fields: [comboId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)

  @@index([comboId])
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum ShippingStatus {
  PENDING
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum InventoryMovementType {
  CREATED
  ADJUSTMENT
  ORDER_DEDUCTION
}

enum CustomerLevel {
  AQUA
  CORAL
  OCEAN
  DIAMOND_SEAL
}

enum PointTransactionType {
  EARNED
  REDEEMED
  EXPIRED
  ADJUSTED
  BONUS
}

model KommoToken {
  id           String   @id @default(cuid())
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model KommoSyncLog {
  id          String          @id @default(cuid())
  entityType  String
  entityId    String
  kommoId     Int?
  status      KommoSyncStatus @default(PENDING)
  operation   String
  error       String?
  retries     Int             @default(0)
  lastAttempt DateTime?
  syncedAt    DateTime?
  payload     Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([entityType, entityId])
  @@index([status])
}

enum KommoSyncStatus {
  PENDING
  IN_PROGRESS
  SUCCESS
  FAILED
  ABANDONED
}

model Quotation {
  id               String          @id @default(cuid())
  number           String          @unique
  sellerId         String
  seller           User            @relation("QuotationSeller", fields: [sellerId], references: [id])
  clientId         String
  client           User            @relation("QuotationClient", fields: [clientId], references: [id])
  status           QuotationStatus @default(DRAFT)
  paymentTerms     String?
  notes            String?
  validUntil       DateTime?
  convertedOrderId String?         @unique
  convertedOrder   Order?          @relation(fields: [convertedOrderId], references: [id])
  sentAt           DateTime?
  approvedAt       DateTime?
  rejectedAt       DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  items            QuotationItem[]

  @@index([sellerId])
  @@index([clientId])
}

model QuotationItem {
  id             String    @id @default(cuid())
  quotationId    String
  quotation      Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId      String?
  product        Product?  @relation(fields: [productId], references: [id])
  name           String
  reference      String?
  manualImageUrl String?
  quantity       Int       @default(1)
  unitPrice      Int       @default(0)
  order          Int       @default(0)

  @@index([quotationId])
}

model QuotationTaxConfig {
  id            String   @id @default(cuid())
  reteIcaPct    Float    @default(1.104)
  reteFuentePct Float    @default(2.5)
  ivaPct        Float    @default(19)
  isActive      Boolean  @default(true)
  updatedAt     DateTime @updatedAt
}

enum QuotationStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
}

model ProductionOrder {
  id             String                @id @default(cuid())
  number         String                @unique
  productionDate DateTime
  status         ProductionOrderStatus @default(DRAFT)
  notes          String?
  createdById    String
  createdBy      User                  @relation("ProductionOrderCreatedBy", fields: [createdById], references: [id])
  approvedById   String?
  approvedBy     User?                 @relation("ProductionOrderApprovedBy", fields: [approvedById], references: [id])
  approvedAt     DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  items          ProductionOrderItem[]
  runs           ProductionRun[]

  @@index([createdById])
  @@index([status])
}

model ProductionOrderItem {
  id                String          @id @default(cuid())
  productionOrderId String
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  productId         String
  product           Product         @relation(fields: [productId], references: [id])
  quantity          Int
  destination       String?
  notes             String?
  order             Int             @default(0)

  @@index([productionOrderId])
  @@index([productId])
}

enum ProductionOrderStatus {
  DRAFT
  APPROVED
  IN_PRODUCTION
  COMPLETED
  CANCELLED
}

model UserPermission {
  id        String      @id @default(cuid())
  userId    String
  module    PanelModule
  canView   Boolean     @default(false)
  canCreate Boolean     @default(false)
  canEdit   Boolean     @default(false)
  canDelete Boolean     @default(false)
  updatedBy String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, module])
  @@index([userId])
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employees Employee[]
}

model Employee {
  id              String         @id @default(cuid())
  userId          String         @unique
  employeeCode    String         @unique
  jobTitle        String
  departmentId    String?
  contractType    ContractType   @default(INDEFINITE)
  status          EmployeeStatus @default(ACTIVE)
  hireDate        DateTime
  terminationDate DateTime?
  salaryAmount    Int?
  salaryCurrency  String         @default("COP")
  salaryPeriod    SalaryPeriod   @default(MONTHLY)
  eps             String?
  afp             String?
  arl             String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id])

  timeOffRequests   TimeOffRequest[]
  attendanceRecords AttendanceRecord[]

  @@index([departmentId])
}

model TimeOffRequest {
  id           String        @id @default(cuid())
  employeeId   String
  type         TimeOffType
  startDate    DateTime
  endDate      DateTime
  durationDays Int
  reason       String?
  status       TimeOffStatus @default(PENDING)
  reviewNote   String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

enum TimeOffType {
  VACATION
  PERMIT
  LEAVE
  INCAPACITY
  UNPAID
}

enum TimeOffStatus {
  PENDING
  APPROVED
  REJECTED
}

model AttendanceRecord {
  id         String           @id @default(cuid())
  employeeId String
  date       DateTime
  status     AttendanceStatus @default(PRESENT)
  note       String?
  createdAt  DateTime         @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

enum ContractType {
  INDEFINITE
  FIXED_TERM
  WORK_OR_LABOR
  APPRENTICESHIP
  TEMPORARY
  CIVIL
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
}

enum SalaryPeriod {
  MONTHLY
  BIWEEKLY
  HOURLY
}

enum WarehouseMovementType {
  ENTRADA
  SALIDA
  TRANSFERENCIA
}

enum WarehouseMovementSource {
  USER
  ODOO
  SYSTEM
}

model Warehouse {
  id            String                  @id @default(cuid())
  key           String                  @unique
  name          String
  order         Int
  stocks        ProductWarehouseStock[]
  movementsFrom WarehouseMovement[]     @relation("MovementFrom")
  movementsTo   WarehouseMovement[]     @relation("MovementTo")
}

model ProductWarehouseStock {
  id          String    @id @default(cuid())
  productId   String
  warehouseId String
  quantity    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
  @@index([warehouseId])
  @@index([productId])
}

model WarehouseMovement {
  id              String                  @id @default(cuid())
  productId       String
  type            WarehouseMovementType
  source          WarehouseMovementSource
  quantity        Int
  fromWarehouseId String?
  toWarehouseId   String?
  note            String?
  userId          String
  createdAt       DateTime                @default(now())
  product         Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  fromWarehouse   Warehouse?              @relation("MovementFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse     Warehouse?              @relation("MovementTo", fields: [toWarehouseId], references: [id])

  @@index([productId])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
}
